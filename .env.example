# API (optional; defaults shown)
# For production or remote backend:
VITE_API_BASE_URL=https://dash.evse.cloud/api
VITE_AUTH_API_BASE_URL=https://dash.evse.cloud/api
# For local dev with Node-RED (charger notifications from your DB): use proxy so requests go to Node-RED
# VITE_API_BASE_URL=/api
# VITE_AUTH_API_BASE_URL=/api
# VITE_API_PROXY_TARGET=http://localhost:1880
VITE_RBAC_ADMIN_SECRET=your_rbac_secret

# Notifications API path (optional). If your backend uses a different path, set it to avoid 404.
# Example: /v4/notifications or /v4/dashboard/notifications
# VITE_NOTIFICATIONS_PATH=/v4/notifications

# Geocode proxy server (optional). Default: 3001. Used when running `npm run server`.
GEOCODE_SERVER_PORT=3001

# Where Vite proxies /api (autocomplete, geocode). Default: http://localhost:3001 (Express).
# If you use Node-RED for the Location API flow, set to Node-RED URL, e.g. http://localhost:1880
VITE_GEOCODE_PROXY_TARGET=http://localhost:3001
